// Design tokens — spacing, type, layout, fonts. Single source of truth
// for visual primitives the rest of the template composes against.

// Spacing scale — 4pt vertical rhythm.
#let unit = 4pt
#let s1 = 1 * unit //  4pt
#let s2 = 2 * unit //  8pt
#let s3 = 3 * unit // 12pt
#let s4 = 4 * unit // 16pt
#let s5 = 5 * unit // 20pt

// Type scale — em-relative to body.
#let body-size = 10pt
#let tagline-size = 1.15em
#let heading-size = 1.15em
#let name-size = 2.4em

// Layout
#let page-margin = 0.5in
#let rule-stroke = 0.5pt

// Fonts
#let heading-font = "New Computer Modern"
#let body-font = "New Computer Modern"
